#!/usr/bin/env sh
set -eu

VERSION="0.1.0-dev"
COMMAND="${1:-help}"

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

script_dir() {
  CDPATH= cd -- "$(dirname -- "$0")" && pwd
}

repo_root_guess() {
  DIR="$(script_dir)"
  if [ -d "$DIR/../src/agent_machine" ]; then
    CDPATH= cd -- "$DIR/.." && pwd
    return 0
  fi
  if [ -d "$DIR/../libexec/src/agent_machine" ]; then
    CDPATH= cd -- "$DIR/../libexec" && pwd
    return 0
  fi
  if [ -d "$DIR/../share/agent-machine/src/agent_machine" ]; then
    CDPATH= cd -- "$DIR/../share/agent-machine" && pwd
    return 0
  fi
  return 1
}

delegate_python_cli() {
  ROOT="$(repo_root_guess || true)"
  if [ -n "${ROOT:-}" ] && [ -d "$ROOT/src/agent_machine" ]; then
    PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}" python3 -m agent_machine.cli "$@"
    return $?
  fi
  if command -v agent-machine-py >/dev/null 2>&1; then
    agent-machine-py "$@"
    return $?
  fi
  printf '%s\n' "agent-machine: Python package CLI unavailable; cannot delegate command: $1" >&2
  printf '%s\n' "Install from a repo checkout, install the Python package, or use agent-machine-py." >&2
  return 127
}

delegate_registry_resolver() {
  ROOT="$(repo_root_guess || true)"
  if [ -n "${ROOT:-}" ] && [ -d "$ROOT/src/agent_machine" ]; then
    PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}" python3 -m agent_machine.agent_registry "$@"
    return $?
  fi
  printf '%s\n' "agent-machine: Agent Registry resolver unavailable; repository package sources not found." >&2
  return 127
}

print_help() {
  cat <<'EOF'
agent-machine: SourceOS Agent Machine local node substrate CLI

Usage:
  agent-machine help
  agent-machine version
  agent-machine paths
  agent-machine doctor [--format json]
  agent-machine probe [--format json] [--fail-closed]
  agent-machine render plan <agentpod.json> [--pretty]
  agent-machine render receipt <agentpod.json> [--pretty] [--artifact-path <path>]
  agent-machine render quadlet <agentpod.json> [--compare <file>]
  agent-machine render k8s <agentpod.json> [--compare <file>]
  agent-machine policy resolve <agentpod.json> --policy-dir <dir> --deployment-receipt-id <id> [--expected-status allowed]
  agent-machine registry resolve <agentpod.json> --grant-dir <dir> --requested-agent-identity-ref <ref> --session-ref <ref> [--expected-status active]
  agent-machine activate evaluate <agentpod.json> [policy.json] <grant.json> --deployment-receipt-id <id> [--policy-dir <dir>] [--storage-receipt-dir <dir>] [--pretty]
  agent-machine steer stub-response <request.json> [--status not_configured|noop] [--pretty]
  agent-machine steer serve-stub [--host 127.0.0.1] [--port 8080] [--status not_configured|noop]

This is the bootstrap CLI. It is intentionally conservative: it discovers host/runtime hints and never emits secrets, raw prompts, raw KV-cache contents, or credentials.
EOF
}

print_version() {
  printf 'agent-machine %s\n' "$VERSION"
}

print_paths() {
  cat <<'EOF'
Agent Machine default paths:
  config:   /etc/agent-machine
  state:    /var/lib/agent-machine
  models:   /var/lib/agent-machine/models
  cache:    /var/lib/agent-machine/cache
  evidence: /var/lib/agent-machine/evidence
  runtime:  /run/agent-machine
EOF
}

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

bool_cmd() {
  if have_cmd "$1"; then
    printf 'true'
  else
    printf 'false'
  fi
}

selinux_mode() {
  if have_cmd getenforce; then
    getenforce 2>/dev/null || printf 'unknown'
  else
    printf 'unknown'
  fi
}

cgroup_mode() {
  if [ -f /sys/fs/cgroup/cgroup.controllers ]; then
    printf 'v2'
  elif [ -d /sys/fs/cgroup ]; then
    printf 'v1'
  else
    printf 'unknown'
  fi
}

probe_json() {
  HOSTNAME_VALUE="$(hostname 2>/dev/null || printf 'unknown')"
  OS_VALUE="$(uname -s 2>/dev/null || printf 'unknown')"
  KERNEL_VALUE="$(uname -r 2>/dev/null || printf 'unknown')"
  ARCH_VALUE="$(uname -m 2>/dev/null || printf 'unknown')"
  SELINUX_VALUE="$(selinux_mode)"
  CGROUP_VALUE="$(cgroup_mode)"

  PODMAN_AVAILABLE="$(bool_cmd podman)"
  DOCKER_AVAILABLE="$(bool_cmd docker)"
  SYSTEMD_AVAILABLE="$(bool_cmd systemctl)"
  LVM_AVAILABLE="$(bool_cmd lvs)"
  VULKAN_AVAILABLE="$(bool_cmd vulkaninfo)"
  CUDA_AVAILABLE="$(bool_cmd nvidia-smi)"
  ROCM_AVAILABLE="$(bool_cmd rocminfo)"

  HOSTNAME_ESCAPED="$(json_escape "$HOSTNAME_VALUE")"
  OS_ESCAPED="$(json_escape "$OS_VALUE")"
  KERNEL_ESCAPED="$(json_escape "$KERNEL_VALUE")"
  ARCH_ESCAPED="$(json_escape "$ARCH_VALUE")"
  SELINUX_ESCAPED="$(json_escape "$SELINUX_VALUE")"
  CGROUP_ESCAPED="$(json_escape "$CGROUP_VALUE")"

  cat <<EOF
{
  "specVersion": "0.1.0",
  "kind": "AgentMachineProbe",
  "host": {
    "hostname": "$HOSTNAME_ESCAPED",
    "os": "$OS_ESCAPED",
    "kernel": "$KERNEL_ESCAPED",
    "arch": "$ARCH_ESCAPED"
  },
  "runtime": {
    "systemdAvailable": $SYSTEMD_AVAILABLE,
    "podmanAvailable": $PODMAN_AVAILABLE,
    "dockerAvailable": $DOCKER_AVAILABLE,
    "selinuxMode": "$SELINUX_ESCAPED",
    "cgroupMode": "$CGROUP_ESCAPED"
  },
  "storage": {
    "lvmAvailable": $LVM_AVAILABLE,
    "modelCache": "/var/lib/agent-machine/models",
    "runtimeCache": "/var/lib/agent-machine/cache",
    "evidencePath": "/var/lib/agent-machine/evidence"
  },
  "accelerators": {
    "cpuAvailable": true,
    "vulkanProbeAvailable": $VULKAN_AVAILABLE,
    "cudaProbeAvailable": $CUDA_AVAILABLE,
    "rocmProbeAvailable": $ROCM_AVAILABLE,
    "metalAvailable": false
  },
  "safety": {
    "rawPromptContentIncluded": false,
    "rawKvCacheContentIncluded": false,
    "secretValuesIncluded": false
  }
}
EOF
}

probe_text() {
  printf 'Agent Machine probe summary\n'
  printf '  host: %s %s %s\n' "$(uname -s 2>/dev/null || printf unknown)" "$(uname -r 2>/dev/null || printf unknown)" "$(uname -m 2>/dev/null || printf unknown)"
  if have_cmd podman; then printf '  podman: available\n'; else printf '  podman: unavailable\n'; fi
  if have_cmd docker; then printf '  docker: available\n'; else printf '  docker: unavailable\n'; fi
  if have_cmd lvs; then printf '  lvm: available\n'; else printf '  lvm: unavailable\n'; fi
  if have_cmd vulkaninfo; then printf '  vulkan probe: available\n'; else printf '  vulkan probe: unavailable\n'; fi
  printf '  metal: unavailable on Linux profiles\n'
}

doctor_json() {
  BREW_AVAILABLE="$(bool_cmd brew)"
  PODMAN_AVAILABLE="$(bool_cmd podman)"
  LVM_AVAILABLE="$(bool_cmd lvs)"
  PROBE_SECRET_FREE="true"
  cat <<EOF
{
  "specVersion": "0.1.0",
  "kind": "AgentMachineDoctor",
  "install": {
    "cliVersion": "$VERSION",
    "homebrewAvailable": $BREW_AVAILABLE,
    "bootstrapOnly": true,
    "runtimeDirectoriesManaged": false
  },
  "readiness": {
    "podmanAvailable": $PODMAN_AVAILABLE,
    "lvmAvailable": $LVM_AVAILABLE,
    "probeSecretFree": $PROBE_SECRET_FREE
  },
  "nextActions": [
    "agent-machine probe --format json",
    "review docs/install.md before privileged runtime activation"
  ]
}
EOF
}

doctor_text() {
  printf 'Agent Machine doctor\n'
  print_version | sed 's/^/  /'
  if have_cmd brew; then printf '  homebrew: available\n'; else printf '  homebrew: unavailable\n'; fi
  if have_cmd podman; then printf '  podman: available\n'; else printf '  podman: unavailable\n'; fi
  if have_cmd lvs; then printf '  lvm: available\n'; else printf '  lvm: unavailable\n'; fi
  printf '  bootstrap-only install: true\n'
  printf '  runtime directories managed automatically: false\n'
  printf '  next: agent-machine probe --format json\n'
}

parse_format() {
  FORMAT="text"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --format)
        shift
        FORMAT="${1:-text}"
        ;;
      --format=json)
        FORMAT="json"
        ;;
      --fail-closed)
        # Reserved for future strict safety enforcement.
        ;;
      *)
        ;;
    esac
    shift || true
  done
  printf '%s' "$FORMAT"
}

case "$COMMAND" in
  help|-h|--help)
    print_help
    ;;
  version|--version)
    print_version
    ;;
  paths)
    print_paths
    ;;
  doctor)
    shift || true
    FORMAT="$(parse_format "$@")"
    if [ "$FORMAT" = "json" ]; then
      doctor_json
    else
      doctor_text
    fi
    ;;
  probe)
    shift || true
    FORMAT="$(parse_format "$@")"
    if [ "$FORMAT" = "json" ]; then
      probe_json
    else
      probe_text
    fi
    ;;
  render)
    shift || true
    delegate_python_cli render "$@"
    ;;
  policy)
    shift || true
    delegate_python_cli policy "$@"
    ;;
  registry)
    shift || true
    if [ "${1:-}" = "resolve" ]; then
      shift || true
      delegate_registry_resolver "$@"
    else
      printf '%s\n' "agent-machine: unsupported registry subcommand: ${1:-<missing>}" >&2
      exit 2
    fi
    ;;
  activate)
    shift || true
    delegate_python_cli activate "$@"
    ;;
  steer)
    shift || true
    delegate_python_cli steer "$@"
    ;;
  *)
    print_help
    exit 2
    ;;
esac
