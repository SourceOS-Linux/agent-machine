#!/usr/bin/env bash
set -euo pipefail

echo "agent-machine credential surface"
echo "expected secrets: none currently declared"
echo "redaction: required"

echo
echo "configured credential-adjacent paths:"
for p in "$HOME/.config/agent-machine" "$HOME/.local/state/agent-machine"; do
  if [ -e "$p" ]; then
    echo "  exists: $p"
    find "$p" -maxdepth 2 -type f 2>/dev/null | sed 's#^#    file: #' | sed -E 's/(token|key|secret|password|auth|oauth|provider)/<redacted-name>/Ig'
  else
    echo "  missing: $p"
  fi
done

echo
echo "policy: declare any future model-provider, registry, policy, evidence, OAuth, keychain, or API-key storage in TRUST_SURFACE.yaml"
