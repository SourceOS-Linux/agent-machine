#!/usr/bin/env bash
set -euo pipefail

echo "agent-machine network surface"
echo "declared listeners: none until provider activation ships"
echo "declared egress: none until provider/model registry/evidence integration ships"

echo
echo "observed listeners:"
if command -v lsof >/dev/null 2>&1; then
  lsof -nP -iTCP -sTCP:LISTEN 2>/dev/null | grep -Ei 'agent-machine|llama|vllm|sglang|ollama|mlx|openai-compatible' || echo "  none"
else
  echo "  lsof unavailable"
fi

echo
echo "policy: update TRUST_SURFACE.yaml before adding listeners, model-provider endpoints, replication, telemetry, or evidence egress"
