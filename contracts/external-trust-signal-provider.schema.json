        "maxAgeSeconds",
        "observedAgeSeconds",
        "fresh"
      ],
      "properties": {
        "maxAgeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "observedAgeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "fresh": {
          "type": "boolean"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "observed", "signatureRef", "signerRef"],
