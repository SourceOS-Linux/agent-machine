{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.org/schemas/agent-machine/lifecycle.schema.json",
  "title": "Agent Machine Lifecycle Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "machine_id",
    "service_id",
    "lifecycle_state",
    "runtime_boundary",
    "receipt_refs"
  ],
  "properties": {
    "machine_id": {
      "type": "string",
      "pattern": "^agent-machine\\.[a-z0-9][a-z0-9.-]*$"
    },
    "service_id": {
      "type": "string",
      "const": "svc.substrate.agent-machine"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["declared", "provisioning", "ready", "running", "degraded", "retired"]
    },
    "runtime_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local_only", "network_policy"],
      "properties": {
        "local_only": {"type": "boolean"},
        "network_policy": {"type": "string", "enum": ["none", "mesh-optional", "restricted", "denied"]},
        "mount_scope": {"type": "string", "default": "workspace"}
      }
    },
    "agentos_handoff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "target_service_id": {"type": "string", "default": "svc.managed.agentos"}
      }
    },
    "receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    }
  }
}
